    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How can I tell if marketing copy was written by AI?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Common tells: parallel sentence structures, hedging phrases like 'in today's landscape,' generic adjectives ('robust,' 'comprehensive'), and an absence of specific examples or numbers. Add concrete details, named clients, and unusual phrasings during human review to break the AI cadence."
          }
        },
        {
          "@type": "Question",
          "name": "What is the best AI tool for writing marketing copy?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "There is no single best tool. Claude tends to handle longer-form content with brand voice constraints well; ChatGPT is faster for short-form social posts; specialized tools like Copy.ai or Jasper add brand-voice memory features. Pick based on the length of content and how much voice consistency you need."
          }
        },
        {
          "@type": "Question",
          "name": "Should I disclose that I used AI to write marketing copy?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Disclosure is rarely required for marketing copy that has been edited by a human. Most platforms (Google, LinkedIn) only require disclosure for synthetic media or for fully unedited AI output. When in doubt, treat the copy as a draft - the final voice and accuracy are yours."
          }
        }
      ]
    }
